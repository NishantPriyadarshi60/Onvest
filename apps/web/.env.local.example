# Backend / API (use when API is separate; for app router same host)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Direct Postgres (for migrations, local dev; Supabase uses REST API separately)
DATABASE_URL=postgresql://user:password@localhost:5432/postgres
DATABASE_SCHEMA=public

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Privy (NEXT_PUBLIC_* in client; PRIVY_JWT_VERIFICATION_KEY from Dashboard > App Settings)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_JWT_VERIFICATION_KEY=

# Persona KYC (S3-1) - from dashboard.withpersona.com
PERSONA_API_KEY=
PERSONA_INQUIRY_TEMPLATE_ID=
PERSONA_WEBHOOK_SECRET=

# DocuSign (embedded signing, S4-1)
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_IMPERSONATED_USER_ID=
DOCUSIGN_PRIVATE_KEY=     # RSA private key (PEM PKCS#8)
DOCUSIGN_ACCOUNT_ID=      # optional; auto-fetched from userinfo if unset
DOCUSIGN_AUTH_SERVER=account-d.docusign.com
DOCUSIGN_API_BASE=        # optional; e.g. https://demo.docusign.net
DOCUSIGN_WEBHOOK_SECRET=  # from Connect HMAC config (for webhooks app)

# Stripe (S6-1) - create products/prices in Stripe Dashboard first
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=   # Price ID for $499/mo
STRIPE_PRICE_GROWTH=    # Price ID for $1499/mo
STRIPE_PRICE_PRO=       # Price ID for $3499/mo

# Polygon & deployer (server-only, S5 blockchain)
NEXT_PUBLIC_POLYGON_RPC=     # public RPC (client fallback)
POLYGON_RPC_URL=             # server RPC (optional; falls back to NEXT_PUBLIC_POLYGON_RPC)
DEPLOYER_WALLET_PRIVATE_KEY= # 0x... deployer wallet for contract writes
FACTORY_CONTRACT_ADDRESS=    # deployed FundFactory address (from apps/blockchain deploy)
CHAIN_ID=137                 # 137=Polygon, 80002=Polygon Amoy

# Resend
RESEND_API_KEY=

# Investor invite JWT (symmetric secret for invite links)
INVITE_JWT_SECRET=
